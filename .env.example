# Public URL of this service (used to build download links the GPT hands the user).
# On Railway this is auto-detected from RAILWAY_PUBLIC_DOMAIN — you can leave it as-is.
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Secret the custom GPT must send in the X-API-Key header. Generate a long random string.
API_KEY=replace-with-a-long-random-secret

# How long generated PDFs stay downloadable.
OUTPUT_TTL_MINUTES=120

# --- Optional: server-side extraction (leave disabled; the GPT does extraction) ---
EXTRACTION_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
